PORT=3000
# Enable approved data connectors. Reddit uses its public JSON search endpoint.
ENABLE_REDDIT=false
YOUTUBE_API_KEY=
# Optional translation service compatible with LibreTranslate.
LIBRETRANSLATE_URL=
LIBRETRANSLATE_API_KEY=
# Optional POST webhook returning an array of normalized social posts.
SOCIAL_INGEST_WEBHOOK=
# Optional model-backed multilingual NLP. When set, Refresh feeds sends
# last-24-hour post text to OpenAI for analysis and semantic embeddings.
OPENAI_API_KEY=
OPENAI_NLP_MODEL=gpt-5.4-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_BASE_URL=https://api.openai.com/v1
